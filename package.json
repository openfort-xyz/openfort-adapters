{
	"name": "@openfort/adapters",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"dev": "turbo dev",
		"lint": "turbo lint",
		"check": "turbo check",
		"format": "turbo format",
		"ci": "turbo build && turbo check && turbo test",
		"test": "turbo test -- run",
		"publish-packages": "turbo run lint check build && changeset publish",
		"changeset": "changeset",
		"changeset:version": "pnpm install --lockfile-only && changeset version",
		"changeset:publish": "pnpm build && changeset publish"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.31.0",
		"prettier": "^3.8.3",
		"turbo": "^2.9.6",
		"typescript": "5.9.3"
	},
	"pnpm": {
		"overrides": {
			"axios@<1.15.0": ">=1.15.0",
			"picomatch@<2.3.2": ">=2.3.2",
			"picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
			"defu@<=6.1.4": ">=6.1.5",
			"flatted@<3.4.2": ">=3.4.2",
			"kysely@>=0.26.0 <=0.28.13": ">=0.28.14",
			"brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
			"minimatch@<10.2.3": ">=10.2.3",
			"vite@<=6.4.1": ">=6.4.2",
			"follow-redirects@<=1.15.11": ">=1.16.0"
		}
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"packageManager": "pnpm@10.19.0",
	"engines": {
		"node": ">=18"
	}
}
